# Copy to infra/.env and fill in values before `make up`.

ENV=dev

# Postgres
POSTGRES_USER=hiremesh
POSTGRES_PASSWORD=hiremesh
POSTGRES_DB=hiremesh

# JWT — generate with `openssl rand -base64 48`
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# In production over HTTPS, set COOKIE_SECURE=true
COOKIE_SECURE=false

# First-boot admin (only used when the users table is empty)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login
BOOTSTRAP_ADMIN_NAME=Admin

# Object storage. In dev these point at the bundled MinIO container; in prod
# point them at Cloudflare R2 or any other S3-compatible service.
#   S3_ENDPOINT          — internal URL the api/worker use to write/read
#   S3_PUBLIC_ENDPOINT   — host-resolvable URL we put into pre-signed download
#                          links so the browser can fetch them directly
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=hiremesh
S3_REGION=us-east-1

# LLM. Default `fake` produces deterministic dummy outputs without calling
# any model — useful for dev/testing without an API key. Set to a real model
# id (e.g. `gpt-4o-mini`, `openrouter/openai/gpt-4o-mini`,
# `anthropic/claude-haiku-4-5`) and provide LLM_API_KEY (or the provider's
# own env var, e.g. OPENROUTER_API_KEY) for real calls.
LLM_PARSE_MODEL=fake
LLM_EMBED_MODEL=fake

# Embedding vector dim. MUST match what your embed model returns.
#   text-embedding-3-small      → 1536  (default)
#   text-embedding-3-large      → 3072
#   voyage-3-large              → 1024
#   cohere/embed-english-v3.0   → 1024
#   nomic-embed-text (Ollama)   →  768
# To change after deploy: update this var, `make up`, then call
# `POST /api/admin/embeddings/reset?confirm=true` to recreate the table.
LLM_EMBED_DIM=1536

# Optional. If unset, LiteLLM reads the provider-specific env var
# (OPENROUTER_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY, etc.) so you can
# mix providers — e.g. OpenRouter for parsing + OpenAI for embeddings.
LLM_API_KEY=
